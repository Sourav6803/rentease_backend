{
  "name": "server",
  "version": "1.0.0",
  "description": "RentEase Ecommerce Platform",
  "main": "src/app.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "prod": "pm2 start ecosystem.config.js --env production",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "seed": "node scripts/seed.js",
    "seed:prod": "NODE_ENV=production node scripts/seed.js",
    "seed:super-admin": "node scripts/seed-super-admin.js",
    "seed:demo-vendor": "node scripts/seed-demo-vendor.js",
    "migrate": "node scripts/migrate.js",
    "backup": "node scripts/backup.js",
    "create-indexes": "node scripts/createIndexes.js",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:build": "docker-compose build",
    "prepare": "husky install || true"
  },
  "keywords": [
    "Ecommerce"
  ],
  "author": "Sourav Bhukta",
  "license": "ISC",
  "dependencies": {
    "@elastic/elasticsearch": "^9.3.4",
    "@google/genai": "^2.11.0",
